#!/usr/bin/env bash
# healthpanel — detailed system + battery health from /proc, /sys and upower.
# Pure Bash; the CLI companion to the HealthPanel Plasma widget.
set -euo pipefail
export LC_NUMERIC=C   # so printf/awk use '.' as decimal separator regardless of locale

# First battery device (BAT0/BAT1/vendor name); overridable with $BAT_DIR.
BAT_DIR="${BAT_DIR:-$(for d in /sys/class/power_supply/*; do
    [ "$(cat "$d/type" 2>/dev/null)" = Battery ] && echo "$d" && break
done)}"
BAT_DIR="${BAT_DIR:-/sys/class/power_supply/BAT0}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/healthpanel"
HISTORY_FILE="$STATE_DIR/history.tsv"
SMART_CACHE="/var/lib/healthpanel/smart.json"
SAMPLE="${HP_SAMPLE:-0.4}"   # seconds between rate snapshots

# ---------- colors ----------
if [[ -t 1 ]] && command -v tput >/dev/null 2>&1 && [[ $(tput colors 2>/dev/null || echo 0) -ge 8 ]]; then
    C_RESET=$(tput sgr0); C_BOLD=$(tput bold); C_DIM=$(tput dim)
    C_RED=$(tput setaf 1); C_GREEN=$(tput setaf 2); C_YELLOW=$(tput setaf 3)
    C_BLUE=$(tput setaf 4); C_MAGENTA=$(tput setaf 5); C_CYAN=$(tput setaf 6)
else
    C_RESET=""; C_BOLD=""; C_DIM=""; C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_MAGENTA=""; C_CYAN=""
fi

die() { printf '%s\n' "$*" >&2; exit 1; }

# ---------- generic helpers ----------
read_sys() { local f="$BAT_DIR/$1"; [[ -r "$f" ]] && cat "$f" 2>/dev/null || true; }
to_unit() {
    local raw="${1:-}" suffix="${2:-}"
    [[ -z "$raw" || "$raw" == "0" ]] && { printf 'n/a'; return; }
    awk -v v="$raw" -v s="$suffix" 'BEGIN{ printf "%.2f %s", v/1000000, s }'
}
percent_of() {
    local a="$1" b="$2"
    [[ -z "$a" || -z "$b" || "$b" == "0" ]] && { printf 'n/a'; return; }
    awk -v a="$a" -v b="$b" 'BEGIN{ printf "%.1f", (a/b)*100 }'
}
bar() {
    local p="${1:-0}" width="${2:-20}"
    [[ "$p" == "n/a" ]] && { printf '%*s' "$width" ""; return; }
    local filled empty
    filled=$(awk -v p="$p" -v w="$width" 'BEGIN{ f=int(p/100*w + 0.5); if(f>w)f=w; if(f<0)f=0; print f }')
    empty=$((width - filled))
    [[ $filled -gt 0 ]] && printf '%s' "$(printf '█%.0s' $(seq 1 "$filled"))"
    [[ $empty  -gt 0 ]] && printf '%s' "$(printf '░%.0s' $(seq 1 "$empty"))"
}
load_color() {  # green<60, yellow<85, red
    awk -v p="${1:-0}" -v g="$C_GREEN" -v y="$C_YELLOW" -v r="$C_RED" 'BEGIN{
        if (p>=85) printf "%s",r; else if (p>=60) printf "%s",y; else printf "%s",g }'
}
health_color() {
    local p="${1:-0}"; [[ "$p" == "n/a" ]] && { printf '%s' "$C_DIM"; return; }
    awk -v p="$p" -v g="$C_GREEN" -v y="$C_YELLOW" -v r="$C_RED" 'BEGIN{
        if (p>=90) printf "%s",g; else if (p>=75) printf "%s",y; else printf "%s",r }'
}
hr()  { printf '  %s%s%s\n' "$C_DIM" "──────────────────────────────────────────────" "$C_RESET"; }
sec() { printf '\n  %s%s%s\n' "$C_BOLD$C_CYAN" "$1" "$C_RESET"; }
kv()  { printf '  %-15s %s\n' "$1" "$2"; }

# hwmon temperature by chip name (first match) -> °C integer, or empty
hwmon_temp() {
    local want="$1" h n
    for h in /sys/class/hwmon/hwmon*; do
        n=$(cat "$h/name" 2>/dev/null) || continue
        [[ "$n" == "$want" ]] || continue
        [[ -r "$h/temp1_input" ]] && { awk -v v="$(cat "$h/temp1_input")" 'BEGIN{printf "%d", v/1000}'; return; }
    done
}
cpu_temp() {
    local t
    for n in k10temp coretemp zenpower cpu_thermal soc_thermal; do
        t=$(hwmon_temp "$n"); [[ -n "$t" ]] && { printf '%s' "$t"; return; }
    done
}
gpu_temp() {
    local t
    for n in amdgpu radeon i915 nouveau; do
        t=$(hwmon_temp "$n"); [[ -n "$t" ]] && { printf '%s' "$t"; return; }
    done
}

# ---------- system gathering ----------
# CPU busy% from two /proc/stat snapshots, $SAMPLE apart
cpu_busy() {
    local a b
    a=$(awk '/^cpu /{print $2+$3+$4+$5+$6+$7+$8, $5+$6}' /proc/stat)
    sleep "$SAMPLE"
    b=$(awk '/^cpu /{print $2+$3+$4+$5+$6+$7+$8, $5+$6}' /proc/stat)
    awk -v a="$a" -v b="$b" 'BEGIN{
        split(a,A," "); split(b,B," ");
        dt=B[1]-A[1]; di=B[2]-A[2];
        if (dt<=0){print "0.0"; exit}
        p=(1-di/dt)*100; if(p<0)p=0; if(p>100)p=100; printf "%.1f", p }'
}
gather_system() {
    CPU_MODEL=$(awk -F: '/model name/{gsub(/^ +/,"",$2); print $2; exit}' /proc/cpuinfo)
    CPU_CORES=$(awk '/^core id/{print $4}' /proc/cpuinfo | sort -u | wc -l)
    CPU_THREADS=$(nproc)
    CPU_MHZ=$(awk '/cpu MHz/{s+=$4; n++} END{ if(n) printf "%.0f", s/n }' /proc/cpuinfo)
    CPU_BUSY=$(cpu_busy)
    CPU_TEMP=$(cpu_temp)

    # memory (kB)
    while IFS=: read -r k v; do case "$k" in
        MemTotal) MEM_TOTAL=${v// /}; MEM_TOTAL=${MEM_TOTAL%kB} ;;
        MemAvailable) MEM_AVAIL=${v// /}; MEM_AVAIL=${MEM_AVAIL%kB} ;;
        SwapTotal) SWAP_TOTAL=${v// /}; SWAP_TOTAL=${SWAP_TOTAL%kB} ;;
        SwapFree) SWAP_FREE=${v// /}; SWAP_FREE=${SWAP_FREE%kB} ;;
    esac; done < /proc/meminfo

    # disk backing /
    read -r DISK_SRC DISK_USED DISK_SIZE < <(df -B1 --output=source,used,size / | tail -1)
    DISK_TEMP=$(hwmon_temp nvme)

    # network totals (sum of all non-lo interfaces)
    read -r NET_RX NET_TX < <(awk -F'[: ]+' '!/lo:|Inter|face/{rx+=$3; tx+=$11} END{print rx, tx}' /proc/net/dev)

    # power profile
    POWER_PROFILE=$(busctl --user get-property net.hadess.PowerProfiles /net/hadess/PowerProfiles \
        net.hadess.PowerProfiles ActiveProfile 2>/dev/null | grep -oE 'performance|balanced|power-saver' || true)
    [[ -z "$POWER_PROFILE" ]] && POWER_PROFILE=$(busctl --system get-property net.hadess.PowerProfiles \
        /net/hadess/PowerProfiles net.hadess.PowerProfiles ActiveProfile 2>/dev/null | grep -oE 'performance|balanced|power-saver' || true)

    # GPU (first DRM card exposing gpu_busy_percent)
    GPU_BUSY=""; VRAM_USED=""; VRAM_TOTAL=""
    for c in /sys/class/drm/card*/device; do
        [ -r "$c/gpu_busy_percent" ] || continue
        GPU_BUSY=$(cat "$c/gpu_busy_percent")
        VRAM_USED=$(cat "$c/mem_info_vram_used" 2>/dev/null)
        VRAM_TOTAL=$(cat "$c/mem_info_vram_total" 2>/dev/null)
        break
    done
    GPU_TEMP=$(gpu_temp)
    GPU_NAME=$(lspci 2>/dev/null | grep -iE 'vga|3d controller' | head -1 | sed 's/.*: //; s/ (rev.*//')
}

render_system() {
    local gb=1073741824 kb2gb=1048576
    sec "SYSTEM"
    hr
    # CPU
    local lc; lc=$(load_color "$CPU_BUSY")
    kv "CPU" "${CPU_MODEL:-unknown}"
    printf '  %-15s %s%.0f%%%s  %s%s%s%s\n' "Load" "$lc" "$CPU_BUSY" "$C_RESET" \
        "$lc" "$(bar "$CPU_BUSY")" "$C_RESET" ""
    kv "Cores / Threads" "${CPU_CORES:-?} phys · ${CPU_THREADS:-?} logical"
    [[ -n "$CPU_MHZ" ]]  && kv "Frequency" "$(awk -v m="$CPU_MHZ" 'BEGIN{printf "%.2f GHz", m/1000}')"
    [[ -n "$CPU_TEMP" ]] && kv "Temperature" "${CPU_TEMP}°C"
    # RAM
    local used=$((${MEM_TOTAL:-0}-${MEM_AVAIL:-0})) rp
    rp=$(percent_of "$used" "${MEM_TOTAL:-0}")
    printf '  %-15s %s%%%s  %s  (%s / %s GB)\n' "RAM" "$rp" "" "$(bar "$rp")" \
        "$(awk -v u="$used" -v d="$kb2gb" 'BEGIN{printf "%.1f", u/d}')" \
        "$(awk -v t="${MEM_TOTAL:-0}" -v d="$kb2gb" 'BEGIN{printf "%.1f", t/d}')"
    if [[ "${SWAP_TOTAL:-0}" -gt 0 ]]; then
        local sused=$((SWAP_TOTAL-${SWAP_FREE:-0})) sp; sp=$(percent_of "$sused" "$SWAP_TOTAL")
        printf '  %-15s %s%%  (%s / %s GB)\n' "Swap" "$sp" \
            "$(awk -v u="$sused" -v d="$kb2gb" 'BEGIN{printf "%.1f", u/d}')" \
            "$(awk -v t="$SWAP_TOTAL" -v d="$kb2gb" 'BEGIN{printf "%.1f", t/d}')"
    fi
    # Disk
    local dp; dp=$(percent_of "${DISK_USED:-0}" "${DISK_SIZE:-0}")
    printf '  %-15s %s%%%s  %s  (%s / %s GB)\n' "Disk /" "$dp" "" "$(bar "$dp")" \
        "$(awk -v u="${DISK_USED:-0}" -v d="$gb" 'BEGIN{printf "%.0f", u/d}')" \
        "$(awk -v t="${DISK_SIZE:-0}" -v d="$gb" 'BEGIN{printf "%.0f", t/d}')"
    kv "Disk device" "${DISK_SRC:-?}"
    [[ -n "$DISK_TEMP" ]] && kv "Disk temp" "${DISK_TEMP}°C"
    # SMART (from cache if present)
    if [[ -r "$SMART_CACHE" ]] && command -v jq >/dev/null 2>&1; then
        local sv; sv=$(jq -r '.valid' "$SMART_CACHE" 2>/dev/null || echo false)
        if [[ "$sv" == "true" ]]; then
            kv "SSD health" "$(jq -r '"\(.healthPct)%  ·  \(.powerOnHours) h  ·  \(.tbwTB) TBW"' "$SMART_CACHE")"
        fi
    fi
    # GPU
    if [[ -n "${GPU_BUSY:-}" ]]; then
        [[ -n "${GPU_NAME:-}" ]] && kv "GPU" "$GPU_NAME"
        local glc; glc=$(load_color "$GPU_BUSY")
        printf '  %-15s %s%s%%%s  %s%s%s%s\n' "GPU load" "$glc" "$GPU_BUSY" "$C_RESET" \
            "$glc" "$(bar "$GPU_BUSY")" "$C_RESET" "${GPU_TEMP:+  ${GPU_TEMP}°C}"
        if [[ -n "${VRAM_TOTAL:-}" && "${VRAM_TOTAL:-0}" -gt 0 ]]; then
            local vp; vp=$(percent_of "$VRAM_USED" "$VRAM_TOTAL")
            printf '  %-15s %s%%  %s  (%s / %s GB)\n' "VRAM" "$vp" "$(bar "$vp")" \
                "$(awk -v u="$VRAM_USED" -v d="$gb" 'BEGIN{printf "%.1f", u/d}')" \
                "$(awk -v t="$VRAM_TOTAL" -v d="$gb" 'BEGIN{printf "%.1f", t/d}')"
        fi
    fi
    # Network
    kv "Network" "$(awk -v r="${NET_RX:-0}" -v t="${NET_TX:-0}" -v d="$gb" \
        'BEGIN{printf "↓ %.2f GB total · ↑ %.2f GB total", r/d, t/d}')"
    # Power profile
    [[ -n "${POWER_PROFILE:-}" ]] && kv "Power profile" "$POWER_PROFILE"
}

# ---------- battery gathering (unchanged data, system-aware naming) ----------
upower_time_remaining() {
    local upath
    upath=$(upower -e 2>/dev/null | grep -E 'BAT|battery_' | head -n1 || true)
    [[ -z "$upath" ]] && { printf ''; return; }
    upower -i "$upath" 2>/dev/null | awk '
        /time to empty:|time to full:/ { for (i=1;i<=NF;i++) if ($i ~ /^[0-9.,]+$/){val=$i;unit=$(i+1);break}
            gsub(",",".",val)
            if (unit ~ /hour/) printf "%.0f", val*3600
            else if (unit ~ /minute/) printf "%.0f", val*60
            else if (unit ~ /second/) printf "%.0f", val; exit }'
}
human_duration() {
    local s="${1:-}"; [[ -z "$s" || "$s" == "0" ]] && { printf 'n/a'; return; }
    awk -v s="$s" 'BEGIN{ h=int(s/3600); m=int((s%3600)/60); printf "%dh %02dm", h, m }'
}
status_fmt() {
    case "$1" in
        Charging)       printf '%sCharging%s ⚡'     "$C_GREEN"  "$C_RESET" ;;
        Discharging)    printf '%sDischarging%s ↓'   "$C_YELLOW" "$C_RESET" ;;
        Full)           printf '%sFull%s ✓'          "$C_GREEN"  "$C_RESET" ;;
        "Not charging") printf '%sNot charging%s ⏸'  "$C_BLUE"   "$C_RESET" ;;
        *)              printf '%s' "${1:-unknown}" ;;
    esac
}
gather_battery() {
    BAT_PRESENT=$(read_sys present)
    MANUF=$(read_sys manufacturer); MODEL=$(read_sys model_name)
    SERIAL=$(read_sys serial_number | sed 's/^ *//;s/ *$//')
    TECH=$(read_sys technology); STATUS=$(read_sys status)
    CYCLES=$(read_sys cycle_count); CAP_PCT=$(read_sys capacity)
    E_FULL_DESIGN=$(read_sys energy_full_design); E_FULL=$(read_sys energy_full); E_NOW=$(read_sys energy_now)
    V_MIN_DESIGN=$(read_sys voltage_min_design); V_NOW=$(read_sys voltage_now); P_NOW=$(read_sys power_now)
    CHARGE_START=$(read_sys charge_control_start_threshold)
    CHARGE_END=$(read_sys charge_control_end_threshold)
    CHARGE_BEH=$(read_sys charge_behaviour | sed 's/.*\[\([^]]*\)\].*/\1/')
    HEALTH=$(percent_of "$E_FULL" "$E_FULL_DESIGN")
    TIME_REMAIN=$(upower_time_remaining)
}
render_battery() {
    [[ "${BAT_PRESENT:-0}" == "1" ]] || { sec "BATTERY"; hr; kv "" "kein Akku gefunden"; return; }
    local title="Battery"; [[ -n "$MANUF$MODEL" ]] && title="$MANUF $MODEL"
    sec "BATTERY — $title ($(basename "$BAT_DIR"))"
    hr
    local hc; hc=$(health_color "$HEALTH")
    printf '  %-15s %s%s%%%s  %s%s%s\n' "Health" "$hc" "$HEALTH" "$C_RESET" "$hc" "$(bar "$HEALTH")" "$C_RESET"
    kv "Cycles"     "${CYCLES:-n/a}"
    kv "Designed"   "$(to_unit "$E_FULL_DESIGN" Wh)"
    kv "Full (now)" "$(to_unit "$E_FULL" Wh)"
    kv "Remaining"  "$(to_unit "$E_NOW" Wh)  (${CAP_PCT:-n/a}%)"
    printf '  %-15s %s' "Status" "$(status_fmt "${STATUS:-unknown}")"
    if [[ "$STATUS" == "Charging" || "$STATUS" == "Discharging" ]] && [[ -n "$TIME_REMAIN" ]]; then
        local label="left"; [[ "$STATUS" == "Charging" ]] && label="to full"
        printf ' — %s %s' "$(human_duration "$TIME_REMAIN")" "$label"
    fi
    printf '\n'
    kv "Power draw" "$(to_unit "$P_NOW" W)"
    kv "Voltage"    "$(to_unit "$V_NOW" V)  (design min $(to_unit "$V_MIN_DESIGN" V))"
    kv "Technology" "${TECH:-n/a}"
    kv "Serial"     "${SERIAL:-n/a}"
    if [[ -n "$CHARGE_START$CHARGE_END$CHARGE_BEH" ]]; then
        [[ -n "$CHARGE_START" && -n "$CHARGE_END" ]] && kv "Charge limit" "${CHARGE_START}%–${CHARGE_END}%"
        [[ -n "$CHARGE_BEH" ]] && kv "Charge mode" "$CHARGE_BEH"
    fi
}

render_temps() {
    sec "TEMPERATURES"
    hr
    local h n t found=0
    for h in /sys/class/hwmon/hwmon*; do
        n=$(cat "$h/name" 2>/dev/null) || continue
        for t in "$h"/temp*_input; do
            [[ -r "$t" ]] || continue
            local v lbl; v=$(cat "$t" 2>/dev/null); [[ -n "$v" ]] || continue
            lbl=$(cat "${t%_input}_label" 2>/dev/null || true)
            printf '  %-15s %s°C\n' "$n${lbl:+/$lbl}" "$(awk -v x="$v" 'BEGIN{printf "%d", x/1000}')"
            found=1
        done
    done
    [[ $found -eq 0 ]] && kv "" "keine hwmon-Sensoren"
}

# ---------- commands ----------
cmd_all()     { gather_system; render_system; gather_battery; render_battery; printf '\n'; }
cmd_system()  { gather_system; render_system; printf '\n'; }
cmd_battery() { gather_battery; render_battery; printf '\n'; }
cmd_temps()   { render_temps; printf '\n'; }
cmd_raw()     { for f in "$BAT_DIR"/*; do [[ -f "$f" && -r "$f" ]] || continue; printf '%s=%s\n' "$(basename "$f")" "$(cat "$f" 2>/dev/null | tr '\n' ' ')"; done; }
cmd_watch() {
    # Flicker-free live view of the given render function (default cmd_all).
    # Renders to the alternate screen, then on each tick moves the cursor home and
    # overwrites in place (clear-to-EOL per line + clear-to-end) — never blanked.
    local render="${1:-cmd_all}" out
    trap 'tput cnorm 2>/dev/null; tput rmcup 2>/dev/null; exit 0' INT TERM
    tput smcup 2>/dev/null || true
    tput civis 2>/dev/null || true
    while true; do
        out=$("$render")
        printf '\033[H%s\033[J\n  %s(live · Ctrl-C zum Beenden)%s' \
            "${out//$'\n'/$'\033[K'$'\n'}" "$C_DIM" "$C_RESET"
        sleep 1
    done
}
cmd_history() {
    if [[ ! -s "$HISTORY_FILE" ]]; then
        printf '%sNoch keine History — Snapshots schreibt der systemd-Timer täglich.%s\n' "$C_DIM" "$C_RESET"
        return
    fi
    printf '\n  %sBattery History%s — %s\n\n' "$C_BOLD" "$C_RESET" "$HISTORY_FILE"
    printf '  %-19s  %-7s  %-8s  %-8s  %s\n' "Date" "Health%" "FCC(Wh)" "Designed" "Cycles"
    printf '  %s\n' "─────────────────────────────────────────────────────────────"
    awk -F'\t' 'NR>1 { printf "  %-19s  %-7s  %-8s  %-8s  %s\n", $1, $2, $3, $4, $5 }' "$HISTORY_FILE"
    printf '\n'
}
usage() {
    cat <<EOF
healthpanel — detailed system + battery health (CLI companion to the HealthPanel widget)

Usage:
  healthpanel              full report: system + battery
  healthpanel system       only the system section (CPU/RAM/disk/network/power)
  healthpanel battery      only the battery section
  healthpanel temps        all hwmon temperature sensors
  healthpanel --raw        dump all battery sysfs entries (debug)
  healthpanel --history    logged battery history (from the systemd timer)
  healthpanel -w|--watch   live view; combine with any section, e.g.
                           'healthpanel -w system', 'healthpanel temps -w', '-w --raw'
  healthpanel -h|--help    this help
EOF
}

# Parse args: -w/--watch may appear before or after the section name.
WATCH=0; SECTION=""
for a in "$@"; do
    case "$a" in
        -w|--watch|watch) WATCH=1 ;;
        -h|--help|help)   usage; exit 0 ;;
        *)                SECTION="$a" ;;
    esac
done

case "$SECTION" in
    ""|all|show)         RENDER=cmd_all ;;
    system|sys)          RENDER=cmd_system ;;
    battery|bat)         RENDER=cmd_battery ;;
    temps|temp)          RENDER=cmd_temps ;;
    --raw|raw)           RENDER=cmd_raw ;;
    --history|history)   cmd_history; exit 0 ;;   # history is static, not watchable
    *) usage; exit 2 ;;
esac

if [[ $WATCH -eq 1 ]]; then cmd_watch "$RENDER"; else "$RENDER"; fi
