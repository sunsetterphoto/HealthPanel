<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
  <kcfgfile name=""/>

  <group name="General">
    <entry name="refreshSeconds" type="Int">
      <default>2</default>
      <min>1</min>
      <max>30</max>
    </entry>
    <!-- UI language: "system" follows the locale, or "de"/"en" override -->
    <entry name="language" type="String">
      <default>system</default>
    </entry>

    <!-- Detail toggles: rows that appear only when the hardware has the sensor -->
    <entry name="showSmart" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showTemps" type="Bool">
      <default>true</default>
    </entry>
    <!-- New sensor rows (auto-hidden when the hardware lacks the source) -->
    <entry name="showPower" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showVoltage" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showDiskSensor1" type="Bool">
      <default>true</default>
    </entry>
    <!-- CPU core bars: false = physical cores, true = logical cores (threads) -->
    <entry name="cpuCoresLogical" type="Bool">
      <default>false</default>
    </entry>
    <entry name="gpuStyle" type="String">
      <default>sparkline</default>
    </entry>
    <entry name="vramStyle" type="String">
      <default>bar</default>
    </entry>

    <!-- Panel/compact layout: JSON array of icons, each {type, texts:[keys]}.
         type ∈ battery|cpu|ram|disk|net. Default: one battery icon with charge%. -->
    <entry name="panelLayout" type="String">
      <default>[{"type":"battery","texts":["charge"]}]</default>
    </entry>
    <!-- Panel/compact: show only the text values (no icons), divided by a thin line -->
    <entry name="panelTextOnly" type="Bool">
      <default>false</default>
    </entry>

    <!-- Customizable layout: ordered [{id,v}] lists (order + visibility).
         Defaults equal the historical fixed arrangement. -->
    <entry name="systemLayout" type="String">
      <default>[{"id":"powerMode","v":true},{"id":"cpu","v":true},{"id":"gpu","v":true},{"id":"ram","v":true},{"id":"disk","v":true},{"id":"fans","v":true},{"id":"net","v":true}]</default>
    </entry>
    <entry name="batteryLayout" type="String">
      <default>[{"id":"cycles","v":true},{"id":"capacity","v":true},{"id":"status","v":true},{"id":"power","v":true},{"id":"voltage","v":true},{"id":"time","v":true},{"id":"serial","v":false},{"id":"chargeLimit","v":true}]</default>
    </entry>
    <entry name="columnOrder" type="String">
      <default>[{"id":"system","v":true},{"id":"battery","v":true},{"id":"controls","v":true}]</default>
    </entry>

    <!-- Anzeige-Stil pro Metrik: bar | ring | sparkline (netz: text | sparkline) -->
    <entry name="cpuStyle" type="String">
      <default>sparkline</default>
    </entry>
    <entry name="ramStyle" type="String">
      <default>bar</default>
    </entry>
    <entry name="diskStyle" type="String">
      <default>bar</default>
    </entry>
    <entry name="netStyle" type="String">
      <default>sparkline</default>
    </entry>

    <!-- Control column (right): quick-setting detail toggles -->
    <entry name="showInhibit" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showScreenBrightness" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showKbdBrightness" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showVolume" type="Bool">
      <default>true</default>
    </entry>
  </group>
</kcfg>
